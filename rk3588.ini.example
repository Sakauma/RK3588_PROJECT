# RK3588 PCIe FPGA-preprocessed video encoder configuration
UP_LOOP_DMA_CHANNUM=5
DOWN_LOOP_DMA_CHANNUM=4

# Keep callback logs low for real-time capture.
PRINTF_UP_MAG=0

FRAME_WIDTH=1920
FRAME_HEIGHT=1080
VIDEO_CODEC=h265
FRAME_FPS=30
VIDEO_BITRATE=8000000
VIDEO_OUTPUT_PATH=/tmp/rk3588_capture.h265

# FPGA sends gray10le16: 10-bit grayscale samples in a 16-bit little-endian container.
# OSD and 16-bit to 10-bit conversion are completed in FPGA before PCIe transfer.
INPUT_PIXEL_FORMAT=gray10le16
PREFER_MAIN10=0

# gray10le16 to 8-bit NV12 encoder input mapping.
# shift       - Y = raw16 >> RAW16_SHIFT, fastest.
# window      - map RAW16_BLACK_LEVEL..RAW16_WHITE_LEVEL to 0..255.
# auto_window - per-frame histogram stretch, clipping the configured outliers.
RAW16_MAP_MODE=window
RAW16_SHIFT=2
RAW16_BLACK_LEVEL=0
RAW16_WHITE_LEVEL=1023
RAW16_AUTO_LOW_CLIP_PERMILLE=5
RAW16_AUTO_HIGH_CLIP_PERMILLE=5
RAW16_LITTLE_ENDIAN=1
INPUT_HAS_IMG_DMA_HEADER=0

# OSD_MODE:
# burned-in - OSD is already present in FPGA output; never draw software OSD.
# auto      - legacy/software fallback mode when external metadata is supplied.
OSD_MODE=burned-in
OSD_ENABLE=0
OSD_TEST_ENABLE=0

ENCODER_QUEUE_DEPTH=3
